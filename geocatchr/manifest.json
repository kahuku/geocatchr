{
  "manifest_version": 3,
  "name": "GeoGuessr Duel Tracker",
  "version": "0.2.0",
  "description": "Captures DuelFinished websocket payloads and forwards them to a local endpoint.",
  "permissions": ["identity", "storage"],
  "host_permissions": [
    "https://www.geoguessr.com/*",
    "http://localhost:3000/*",
    "https://us-east-1jhgrfzkpz.auth.us-east-1.amazoncognito.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.geoguessr.com/*"],
      "js": ["content-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.geoguessr.com/*"],
      "js": ["content-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}